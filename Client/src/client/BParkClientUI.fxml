                <TableColumn fx:id="colDate" prefWidth="204.0" text="Order Date" />
                <TableColumn fx:id="colSpot" prefWidth="144.0" text="Parking Spot" />
                <TableColumn fx:id="colCode" prefWidth="170.0" text="Confirmation Code" />
                <TableColumn fx:id="colSubscriberID" prefWidth="143.0" text="Subscriber ID" />
