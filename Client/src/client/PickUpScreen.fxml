<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="mainPane" prefHeight="1080" prefWidth="1920" styleClass="main-pane" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.PickUpScreenController">
	<children>
		<Label layoutX="743.0" layoutY="143.0" styleClass="title-label" text="PickUp Screen" />
		<VBox layoutX="499.0" layoutY="380.0" spacing="30.0">
			<children>
				<HBox prefHeight="70.0" prefWidth="970.0" spacing="10.0">
					<children>
						<Label layoutX="446.0" layoutY="385.0" prefHeight="107.0" prefWidth="480.0" styleClass="reg-label" text="Enter Parking Code:">
                     </Label>

						<TextArea fx:id="parkingCode" pickOnBounds="false" prefHeight="70.0" prefWidth="480.0" promptText="Enter code numbers only" snapToPixel="false">
							<font>
								<Font size="36.0" />
							</font>
                     <HBox.margin>
                        <Insets top="10.0" />
                     </HBox.margin>
						</TextArea>

					</children>
				</HBox>
				<HBox prefWidth="970.0" spacing="10.0">
					<children>
						<Button layoutX="446.0" layoutY="494.0" onAction="#submitParkingCode" styleClass="menu-button" text="Submit" />
						<Button layoutX="970.0" layoutY="494.0" onAction="#handleLostCodeRequest" styleClass="menu-button" text="Forgot Code" />
					</children>
				</HBox>
			</children>
		</VBox>
		<Button layoutX="1622.0" layoutY="940.0" onAction="#handleBackButton" styleClass="disconnect-button" text="⬅ Back" />
	</children>
</AnchorPane>
